# @spektrum/shared is a file: dep backed by the spektrum-shared git SUBMODULE.
# install-links MUST be false (npm default) here: with install-links=true npm
# COPIES the submodule into node_modules, and because the package version stays
# 0.1.0 across submodule bumps, Vercel's build cache reuses a stale copy ->
# "export X not found" for anything added since the cached build. install-links
# =false symlinks node_modules/@spektrum/shared -> the submodule, so a pointer
# bump is reflected immediately with no stale copy.
install-links=false
